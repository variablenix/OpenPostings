<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="OpenPostings"
    Manufacturer="OpenPostings"
    Version="$(var.ProductVersion)"
    UpgradeCode="{4A42A7C5-011D-4B3D-B795-BF86A9492338}"
    Language="1033"
    Scope="perMachine">

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OpenPostings">
        <Directory Id="BACKENDFOLDER" Name="backend" />
        <Directory Id="MCPFOLDER" Name="mcp" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuDir" Name="OpenPostings" />
    </StandardDirectory>

    <Feature Id="ProductFeature" Title="OpenPostings" Level="1" Display="expand">
      <Feature
        Id="DesktopAppFeature"
        Title="Desktop App (Required)"
        Description="Installs the OpenPostings desktop application."
        Level="1">
        <ComponentGroupRef Id="AppFiles" />
        <ComponentRef Id="StartMenuShortcutComponent" />
        <ComponentRef Id="DesktopShortcutComponent" />
      </Feature>

      <Feature
        Id="BackendServiceFeature"
        Title="Backend Service Worker"
        Description="Installs the local backend service and keeps it available in the background."
        Level="1">
        <ComponentGroupRef Id="BackendFiles" />
        <ComponentRef Id="BackendAutoStartComponent" />

        <Feature
          Id="McpServiceFeature"
          Title="MCP Apply Agent Server (AI Service Engine)"
          Description="Installs the optional AI service engine used for MCP apply-agent workflows."
          Level="200">
          <ComponentGroupRef Id="McpFiles" />
        </Feature>
      </Feature>
    </Feature>

    <ui:WixUI Id="WixUI_Mondo" />
    <WixVariable Id="WixUILicenseRtf" Value="OpenPostings_License.rtf" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <Property Id="EXISTING_APPDATA_DB">
      <DirectorySearch Id="ExistingAppDataBackendDirectorySearch" Path="[LocalAppDataFolder]OpenPostings\backend">
        <FileSearch Id="ExistingAppDataJobsDbSearch" Name="jobs.db" />
      </DirectorySearch>
    </Property>

    <UI>
      <Dialog
        Id="DatabaseOverwriteWarningDlg"
        Width="370"
        Height="270"
        Title="[ProductName] Setup">
        <Control
          Id="Title"
          Type="Text"
          X="15"
          Y="6"
          Width="340"
          Height="20"
          Transparent="yes"
          NoPrefix="yes"
          Text="{\WixUI_Font_Title}Database Overwrite Warning" />
        <Control
          Id="WarningText"
          Type="Text"
          X="20"
          Y="35"
          Width="330"
          Height="115"
          Text="WARNING: If you have a previous install PLEASE COPY/MOVE your database file from:[LocalAppDataFolder]OpenPostings\backend\jobs.db to another folder before continuing. You can use the migration tool in Sync Settings to merge back data like applications you already applied for. If you do not, you will NOT get the latest updated companies and ATSs from this latest update...." />
        <Control
          Id="Back"
          Type="PushButton"
          X="180"
          Y="243"
          Width="56"
          Height="17"
          Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="CustomizeDlg" Condition="WixUI_InstallMode = &quot;InstallCustom&quot;" />
          <Publish Event="NewDialog" Value="SetupTypeDlg" Condition="WixUI_InstallMode &lt;&gt; &quot;InstallCustom&quot;" />
        </Control>
        <Control
          Id="Next"
          Type="PushButton"
          X="236"
          Y="243"
          Width="56"
          Height="17"
          Default="yes"
          Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="1" />
        </Control>
        <Control
          Id="Cancel"
          Type="PushButton"
          X="304"
          Y="243"
          Width="56"
          Height="17"
          Cancel="yes"
          Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <Publish Dialog="SetupTypeDlg" Control="TypicalButton" Event="NewDialog" Value="DatabaseOverwriteWarningDlg" Order="999" Condition="EXISTING_APPDATA_DB AND NOT Installed" />
      <Publish Dialog="SetupTypeDlg" Control="CompleteButton" Event="NewDialog" Value="DatabaseOverwriteWarningDlg" Order="999" Condition="EXISTING_APPDATA_DB AND NOT Installed" />
      <Publish Dialog="CustomizeDlg" Control="Next" Event="NewDialog" Value="DatabaseOverwriteWarningDlg" Order="999" Condition="EXISTING_APPDATA_DB AND NOT Installed" />
    </UI>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.AppSourceDir)\**" />
    </ComponentGroup>

    <ComponentGroup Id="BackendFiles" Directory="BACKENDFOLDER">
      <Files Include="$(var.BackendSourceDir)\**" />
    </ComponentGroup>

    <ComponentGroup Id="McpFiles" Directory="MCPFOLDER">
      <Files Include="$(var.McpSourceDir)\**" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="BackendAutoStartComponent" Guid="{F3A7AEB1-7A24-4F13-A881-71CCF2F96FA9}">
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Windows\CurrentVersion\Run"
          Name="OpenPostingsBackend"
          Type="string"
          Value="&quot;[INSTALLFOLDER]openpostings.exe&quot; --backend-startup"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="AppProgramMenuDir">
      <Component Id="StartMenuShortcutComponent" Guid="{49F5F38E-521B-4E87-B510-B54EF2BB4F27}">
        <Shortcut
          Id="StartMenuShortcut"
          Name="OpenPostings"
          Description="Launch OpenPostings"
          Target="[INSTALLFOLDER]openpostings.exe"
          WorkingDirectory="INSTALLFOLDER"
          Advertise="no" />
        <RemoveFolder Id="RemoveAppProgramMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\OpenPostings" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComponent" Guid="{63E3611C-EBDB-430F-BACF-510AA4E5D10B}">
        <Shortcut
          Id="DesktopShortcut"
          Name="OpenPostings"
          Description="Launch OpenPostings"
          Target="[INSTALLFOLDER]openpostings.exe"
          WorkingDirectory="INSTALLFOLDER"
          Advertise="no" />
        <RegistryValue Root="HKCU" Key="Software\OpenPostings" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>
  </Fragment>
</Wix>
